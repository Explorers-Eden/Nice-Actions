execute if score $24_hour nice_actions.calendar matches 0 run return run data modify storage eden:calendar global.daypart set value "Midnight"
execute if score $24_hour nice_actions.calendar matches 1..4 run return run data modify storage eden:calendar global.daypart set value "Night"
execute if score $24_hour nice_actions.calendar matches 5..11 run return run data modify storage eden:calendar global.daypart set value "Morning"
execute if score $24_hour nice_actions.calendar matches 12 run return run data modify storage eden:calendar global.daypart set value "Noon"
execute if score $24_hour nice_actions.calendar matches 13..17 run return run data modify storage eden:calendar global.daypart set value "Afternoon"
execute if score $24_hour nice_actions.calendar matches 18..21 run return run data modify storage eden:calendar global.daypart set value "Evening"
execute if score $24_hour nice_actions.calendar matches 22..23 run return run data modify storage eden:calendar global.daypart set value "Night"
